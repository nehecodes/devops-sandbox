# DevOps Sandbox Platform — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# API configuration
API_PORT=5050
FLASK_DEBUG=false

# Default app image for sandbox environments
# Must expose port 80 and respond to GET /health
SANDBOX_APP_IMAGE=kennethreitz/httpbin

# Grafana admin password (used with: make monitoring)
GRAFANA_PASSWORD=sandbox123
